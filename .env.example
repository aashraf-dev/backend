# ─── Application ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_DOMAIN=vetos.com
CORS_ORIGINS=http://localhost:3000,https://vetos.com

# ─── PostgreSQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=supersecret
DB_NAME=vetos_platform

# ─── JWT ─────────────────────────────────────────────────────────────
# Must be >= 64 chars each. Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=changeme_access_64_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=changeme_refresh_64_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Security ────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MFA_APP_NAME=Vetos Platform

# ─── Rate Limiting ───────────────────────────────────────────────────
THROTTLE_SHORT_TTL=1000
THROTTLE_SHORT_LIMIT=10
THROTTLE_MEDIUM_TTL=60000
THROTTLE_MEDIUM_LIMIT=100
THROTTLE_LONG_TTL=3600000
THROTTLE_LONG_LIMIT=1000
